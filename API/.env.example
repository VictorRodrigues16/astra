# Exemplo de variáveis de ambiente da Astra API.
# Copie para .env (que fica FORA do versionamento) e ajuste os valores.
# Em produção, injete via cofre / GitHub Secrets — NUNCA commite segredos.

# Gere sua chave em https://api.nasa.gov (ou use DEMO_KEY para testes).
NASA_API_KEY=DEMO_KEY

PORT=3001

# Origens permitidas no CORS (Zero Trust), separadas por vírgula.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000
